# ============================================================================
# .env.example — medicamentos
# Copie para .env e preencha os valores obrigatórios
# ============================================================================

# === Database (OBRIGATÓRIO — para docker-compose) ===
# Gere uma senha forte: openssl rand -base64 18
DB_PASSWORD=""
DATABASE_URL="postgresql://admin:***@localhost:5432/medicamentos"

# === Authentication (OBRIGATÓRIO) ===
# Gere com: openssl rand -base64 32
AUTH_SECRET=""

# === Admin inicial (OBRIGATÓRIO — usado no seed) ===
ADMIN_EMAIL="admin@seudominio.com.br"
# Gere com: openssl rand -base64 12
ADMIN_PASSWORD=""

# === Site ===
BASE_URL="https://seudominio.com.br"

# === Anvisa (opcionais — URLs públicas oficiais como fallback) ===
# ANVISA_MEDICINES_URL="https://dados.anvisa.gov.br/dados/CONSULTAS/PRODUTOS/TA_CONSULTA_MEDICAMENTOS.CSV"
# ANVISA_PRICES_URL="https://dados.anvisa.gov.br/dados/TA_PRECOS_MEDICAMENTOS.csv"

# === Embeddings (opcional) ===
# Modelo de embedding multilíngue (118MB, melhor qualidade pt-BR)
# Opções: Xenova/multilingual-e5-small (recomendado), Xenova/all-MiniLM-L6-v2 (mais leve)
EMBEDDING_MODEL="Xenova/multilingual-e5-small"

# === Cron (opcional — para sync automático) ===
# CRON_SECRET=""

# === Ambiente ===
NODE_ENV="production"
